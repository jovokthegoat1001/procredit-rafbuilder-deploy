# Backend environment variables.
# Local: copy to `.env` (already gitignored). Railway: set these in the service Variables tab.

# Required — your Anthropic API key (used server-side only; never exposed to the browser).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — preferred model; falls back to the built-in list if unset or unavailable.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — Railway sets PORT automatically; only needed for local non-Docker runs.
PORT=8787
